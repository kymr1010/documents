{
  "scripts": {
    "start": "PORT=5000 marp --server --theme-set ./theme --watch ./",
    "build:html": "marp --html --theme-set ./theme -I ./ -o ./dist && pnpm run build:index",
    "build:index": "node ./scripts/generate-index.mjs",
    "build:pdf": "marp ./*.md --pdf --theme-set ./theme --browser-path /usr/bin/chromium --no-sandbox -o docs/slides.pdf"
  },
  "devDependencies": {
    "@marp-team/marp-cli": "^4.2.3"
  },
  "packageManager": "pnpm@9.12.0"
}
